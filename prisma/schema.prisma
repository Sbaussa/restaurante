generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CASHIER)
  createdAt DateTime @default(now())
  orders    Order[]
}

enum Role {
  ADMIN
  CASHIER
  KITCHEN
  MESERO
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model Product {
  id          Int         @id @default(autoincrement())
  name        String
  price       Float
  stock       Int         @default(0)
  available   Boolean     @default(true)
  imageUrl    String?
  categoryId  Int
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
}

model Order {
  id            Int         @id @default(autoincrement())
  total         Float
  status        OrderStatus @default(PENDING)
  tableNumber   Int?
  notes         String?
  paymentMethod String?
  cashGiven     Float?
  cashChange    Float?
  userId        Int
  user          User        @relation(fields: [userId], references: [id])
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orderType     String?   @default("MESA")   // "MESA" | "DOMICILIO" | "LLEVAR"
  delivery      Delivery?
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  quantity  Int
  unitPrice Float
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
}

// ─── Agregar al final de schema.prisma ───────────────────────────────────────
// Copia estos modelos y pégalos al final de tu archivo prisma/schema.prisma

model BeerBrand {
  id        Int       @id @default(autoincrement())
  name      String    @unique   // "Águila", "Poker", "Club Colombia", etc.
  imageUrl  String?
  active    Boolean   @default(true)
  beers     Beer[]
}

model Beer {
  id            Int           @id @default(autoincrement())
  brandId       Int
  brand         BeerBrand     @relation(fields: [brandId], references: [id])
  presentation  String        // "Botella 330ml", "Lata 269ml", "Paca x12", "Paca x30"
  unitPrice     Float         // Precio por unidad o por paca
  stock         Int           @default(0)
  minStock      Int           @default(10)  // Alerta de stock bajo
  active        Boolean       @default(true)
  saleItems     BeerSaleItem[]
  stockMovements BeerStockMovement[]
  createdAt     DateTime      @default(now())
}

model BeerSale {
  id        Int            @id @default(autoincrement())
  total     Float
  userId    Int
  notes     String?
  items     BeerSaleItem[]
  createdAt DateTime       @default(now())
}

model BeerSaleItem {
  id        Int      @id @default(autoincrement())
  saleId    Int
  sale      BeerSale @relation(fields: [saleId], references: [id])
  beerId    Int
  beer      Beer     @relation(fields: [beerId], references: [id])
  quantity  Int      // Puede ser 1, 3, 4, 5 unidades sueltas o 1 paca
  unitPrice Float
}

// Historial de entradas y salidas de inventario
model BeerStockMovement {
  id        Int           @id @default(autoincrement())
  beerId    Int
  beer      Beer          @relation(fields: [beerId], references: [id])
  type      MovementType  // ENTRADA o SALIDA
  quantity  Int
  reason    String?       // "Compra proveedor", "Venta", "Ajuste", etc.
  userId    Int
  createdAt DateTime      @default(now())
}

enum MovementType {
  ENTRADA
  SALIDA
}
model Delivery {
  id           Int    @id @default(autoincrement())
  orderId      Int    @unique
  order        Order  @relation(fields: [orderId], references: [id])
  customerName String?
  phone        String?
  address      String
}